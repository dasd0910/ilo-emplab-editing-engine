# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env — it's in .gitignore.

# --- LLM providers (in fallback order; any one works, more = better quota) ---

# Google Gemini — https://aistudio.google.com/apikey
# Free tier: ~1,500 requests/day; highest editing quality.
GEMINI_API_KEY=your_gemini_key_here

# Groq — https://console.groq.com/keys
# Free tier: 100,000 tokens/day; very fast, lower quality than Gemini.
GROQ_API_KEY=your_groq_key_here

# Cerebras — https://cloud.cerebras.ai
# Free tier generous; fastest inference on Llama 3.3 70B.
CEREBRAS_API_KEY=your_cerebras_key_here

# Mistral — https://console.mistral.ai
# Free tier (La Plateforme): reasonable limits; good quality.
MISTRAL_API_KEY=your_mistral_key_here

# Password gate (deployed app only). Leave blank for local dev / no gate.
APP_PASSWORD=pick_a_strong_password
